APP_NAME="ATS Backend"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ============================================================
# LOGGING - Error level for production
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================================
# DATABASE - Use MySQL in production (SQLite not recommended)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ats_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ============================================================
# SESSION & AUTHENTICATION
# ============================================================
SESSION_DRIVER=cookie
SESSION_LIFETIME=1440
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none
AUTH_TOKEN_COOKIE=ats_auth_token

# ============================================================
# BROADCAST & QUEUE
# ============================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
CV_STORAGE_DISK=s3
QUEUE_CONNECTION=redis

# ============================================================
# CACHE - Redis recommended for production
# ============================================================
CACHE_STORE=redis
CACHE_TTL=3600
CACHE_PREFIX=

# ============================================================
# REDIS
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_SCHEME=tcp
REDIS_DB=0
REDIS_CACHE_DB=1

MEMCACHED_HOST=127.0.0.1

# ============================================================
# MAIL
# ============================================================
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# SANCTUM - Token-based authentication
# ============================================================
SANCTUM_STATEFUL_DOMAINS=yourdomain.vercel.app,api.yourdomain.com
SANCTUM_ENCRYPT_COOKIES=true
SANCTUM_TOKEN_EXPIRATION=

# ============================================================
# AWS S3 - For persistent CV storage
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket-name
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# VITE (Frontend assets)
# ============================================================
VITE_APP_NAME="${APP_NAME}"
